# Node / TypeScript (workspace)
##############################

# Dependencies (any module)
node_modules/
**/node_modules/

# Build output
dist/
**/dist/

# TypeScript incremental build cache
*.tsbuildinfo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Env files (secrets)
.env
.env.*
!.env.example

# OS / editor junk
.DS_Store
Thumbs.db

# IDE settings (optional)
.vscode/
.idea/

# Cursor (optional)
.cursor/
